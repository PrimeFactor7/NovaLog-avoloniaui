<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NovaLog.Avalonia.ViewModels"
             x:Class="NovaLog.Avalonia.Controls.TimeSyncBar"
             x:DataType="vm:TimeSyncBarViewModel"
             Height="22"
             IsVisible="{Binding IsVisible}"
             Background="{DynamicResource ToolBarBgBrush}">
  <Grid>
    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0">
      <!-- Time sync icon (Codicon: history) -->
      <TextBlock Text="&#xEA74;"
                 FontFamily="{StaticResource CodiconFont}"
                 FontSize="14"
                 Foreground="{DynamicResource AccentBrush}"
                 VerticalAlignment="Center" />
      
      <!-- Timestamp Text -->
      <TextBlock Text="{Binding TimestampText}"
                 FontFamily="Cascadia Mono, Consolas, Courier New"
                 FontSize="11"
                 Foreground="{DynamicResource AccentBrush}"
                 Margin="8,0"
                 VerticalAlignment="Center" />

      <!-- Clear Button -->
      <Button Command="{Binding ClearCommand}"
              Background="Transparent"
              BorderThickness="0"
              Padding="4"
              VerticalAlignment="Center"
              Cursor="Hand">
        <TextBlock Text="&#xEA76;"
                   FontFamily="{StaticResource CodiconFont}"
                   FontSize="12"
                   Foreground="{DynamicResource DimTextBrush}" />
      </Button>
    </StackPanel>
    
    <!-- Bottom Separator -->
    <Border Height="1" 
            Background="{DynamicResource SeparatorBrush}" 
            VerticalAlignment="Bottom" />
  </Grid>
</UserControl>
