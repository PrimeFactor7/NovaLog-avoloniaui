<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:docking="using:NovaLog.Avalonia.Docking"
             xmlns:vm="using:NovaLog.Avalonia.ViewModels"
             xmlns:views="using:NovaLog.Avalonia.Views"
             x:Class="NovaLog.Avalonia.App"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <docking:DockViewLocator />
        <DataTemplate DataType="docking:LogViewDocument">
            <views:LogViewPanel DataContext="{Binding Context}" />
        </DataTemplate>
        <DataTemplate DataType="vm:LogViewViewModel">
            <views:LogViewPanel />
        </DataTemplate>
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://NovaLog.Avalonia/Styles/LogThemeResources.axaml" />
            </ResourceDictionary.MergedDictionaries>
            <FontFamily x:Key="CodiconFont">avares://NovaLog.Avalonia/Assets/Fonts/codicon.ttf#codicon</FontFamily>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Dock.Avalonia.Themes.Simple/DockSimpleTheme.axaml" />
        <StyleInclude Source="avares://Avalonia.Controls.TreeDataGrid/Themes/Fluent.axaml"/>
        <StyleInclude Source="avares://NovaLog.Avalonia/Styles/NeonSidebar.axaml" />
        <StyleInclude Source="avares://NovaLog.Avalonia/Styles/SegmentedControl.axaml" />
        <StyleInclude Source="avares://NovaLog.Avalonia/Styles/DockNeon.axaml" />
    </Application.Styles>
</Application>
