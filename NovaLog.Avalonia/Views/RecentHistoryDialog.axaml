<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NovaLog.Avalonia.ViewModels"
        x:Class="NovaLog.Avalonia.Views.RecentHistoryDialog"
        x:DataType="vm:RecentHistoryDialogViewModel"
        Title="Recent History"
        Width="920" Height="520"
        MinWidth="720" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}">

  <Grid RowDefinitions="Auto,*,Auto" Margin="16">
    <StackPanel Spacing="4">
      <TextBlock Text="Recent History"
                 FontSize="18"
                 FontWeight="Bold"
                 Foreground="{DynamicResource AccentBrush}" />
      <TextBlock Text="Single-click previews the entry in the active pane. Double-click or use Add To Sources to attach it to the source list."
                 Foreground="{DynamicResource DimTextBrush}"
                 TextWrapping="Wrap" />
    </StackPanel>

    <Grid Grid.Row="1" RowDefinitions="*,Auto" Margin="0,16,0,16">
      <Border BorderBrush="{DynamicResource SeparatorBrush}"
              BorderThickness="1"
              CornerRadius="6"
              Background="{DynamicResource PanelBgBrush}">
        <ListBox x:Name="RecentListBox"
                 ItemsSource="{Binding Items}"
                 SelectedItem="{Binding SelectedItem}"
                 DoubleTapped="OnRecentDoubleTapped"
                 SelectionChanged="OnRecentSelectionChanged"
                 Background="Transparent"
                 BorderThickness="0">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:RecentHistoryItemViewModel">
              <Border Padding="10,8">
                <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="12">
                  <TextBlock Grid.Column="0"
                             Text="&#xE8E5;"
                             FontFamily="Segoe MDL2 Assets, Avalonia.Fonts.Inter"
                             Foreground="{DynamicResource AccentBrush}"
                             VerticalAlignment="Top" />

                  <StackPanel Grid.Column="1" Spacing="2">
                    <TextBlock Text="{Binding DisplayName}"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding Entry.Path}"
                               Foreground="{DynamicResource DimTextBrush}"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding Location}"
                               Foreground="{DynamicResource DimTextBrush}"
                               FontSize="10"
                               TextTrimming="CharacterEllipsis" />
                  </StackPanel>

                  <StackPanel Grid.Column="2" Spacing="2" HorizontalAlignment="Right">
                    <TextBlock Text="Kind"
                               Foreground="{DynamicResource DimTextBrush}"
                               FontSize="10" />
                    <TextBlock Text="{Binding KindLabel}" />
                  </StackPanel>

                  <StackPanel Grid.Column="3" Spacing="2" HorizontalAlignment="Right">
                    <TextBlock Text="Last Used"
                               Foreground="{DynamicResource DimTextBrush}"
                               FontSize="10" />
                    <TextBlock Text="{Binding LastUsedText}" />
                    <TextBlock Text="{Binding LastModifiedText, StringFormat='Modified {0}'}"
                               Foreground="{DynamicResource DimTextBrush}"
                               FontSize="10" />
                  </StackPanel>

                  <Border Grid.Column="4"
                          Padding="8,4"
                          CornerRadius="12"
                          Background="{DynamicResource ToolBarBgBrush}"
                          BorderBrush="{DynamicResource SeparatorBrush}"
                          BorderThickness="1"
                          VerticalAlignment="Top">
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="{DynamicResource DimTextBrush}"
                               FontSize="10" />
                  </Border>
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="Padding" Value="0" />
              <Setter Property="Background" Value="Transparent" />
              <Setter Property="CornerRadius" Value="4" />
              <Setter Property="Margin" Value="4,2" />
            </Style>
            <Style Selector="ListBoxItem:pointerover">
              <Setter Property="Background" Value="{DynamicResource TabHoverBgBrush}" />
            </Style>
            <Style Selector="ListBoxItem:selected">
              <Setter Property="Background" Value="{DynamicResource TabActiveBgBrush}" />
            </Style>
          </ListBox.Styles>
        </ListBox>
      </Border>

      <Border Grid.Row="1"
              Margin="0,10,0,0"
              Padding="12,8"
              CornerRadius="6"
              BorderBrush="{DynamicResource SeparatorBrush}"
              BorderThickness="1"
              Background="{DynamicResource ToolBarBgBrush}">
        <Grid ColumnDefinitions="Auto,*">
          <TextBlock Text="Selected"
                     Foreground="{DynamicResource DimTextBrush}"
                     VerticalAlignment="Center" />
          <TextBlock Grid.Column="1"
                     Margin="10,0,0,0"
                     Text="{Binding SelectedItem.Entry.Path}"
                     TextTrimming="CharacterEllipsis"
                     VerticalAlignment="Center" />
        </Grid>
      </Border>
    </Grid>

    <StackPanel Grid.Row="2"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8">
      <Button x:Name="BtnAdd"
              Content="Add To Sources"
              Width="132"
              Classes="neon-action"
              IsEnabled="{Binding CanAddSelected}" />
      <Button x:Name="BtnClose"
              Content="Close"
              Width="90"
              Classes="neon-action" />
    </StackPanel>
  </Grid>
</Window>
