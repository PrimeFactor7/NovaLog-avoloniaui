<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NovaLog.Avalonia.ViewModels"
             xmlns:controls="using:NovaLog.Avalonia.Controls"
             xmlns:views="using:NovaLog.Avalonia.Views"
             x:Class="NovaLog.Avalonia.Views.LogViewPanel"
             x:DataType="vm:LogViewViewModel"
             Focusable="True"
             DragDrop.AllowDrop="True">

  <UserControl.KeyBindings>
    <KeyBinding Gesture="Ctrl+P" Command="{Binding ShowPickerCommand}" />
  </UserControl.KeyBindings>

  <UserControl.Styles>
    <!-- Sync toggle: link-external (unlinked, dim) / link (synced, neon cyan accent) -->
    <Style Selector="ToggleButton.sync-toggle TextBlock">
      <Setter Property="Text" Value="&#xea5c;" />
      <Setter Property="FontFamily" Value="{StaticResource CodiconFont}" />
      <Setter Property="Foreground" Value="{DynamicResource DimTextBrush}" />
    </Style>
    <Style Selector="ToggleButton.sync-toggle:checked TextBlock">
      <Setter Property="Text" Value="&#xea5b;" />
      <Setter Property="FontFamily" Value="{StaticResource CodiconFont}" />
      <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    </Style>
  </UserControl.Styles>

  <Grid x:Name="RootGrid" RowDefinitions="Auto,*,0,0">
    <!-- Pane header (compact) -->
    <Border Grid.Row="0" Height="32"
            Background="{DynamicResource ToolBarBgBrush}"
            Padding="6,4"
            ZIndex="100"
            ClipToBounds="False"
            x:Name="HeaderBorder">
      <Panel>
        <DockPanel>
          <!-- Right: Close -->
          <Button DockPanel.Dock="Right" Classes="neon-action pane-header-btn" Content="&#x2715;"
                  Command="{Binding ClosePaneCommand}"
                  Background="Transparent" BorderThickness="0"
                  Foreground="{DynamicResource DimTextBrush}"
                  ToolTip.Tip="Close pane&#x0a;Remove this pane from the view (source stays in list)" />
          <!-- Right: Link status toggle -->
          <ToggleButton DockPanel.Dock="Right" Classes="neon-action pane-header-btn sync-toggle"
                        IsChecked="{Binding IsLinked}"
                        Background="Transparent" BorderThickness="0"
                        Margin="0,0,8,0"
                        ToolTip.Tip="Time sync (Ctrl+L)&#x0a;Link panes to share timestamp during scroll"
                        AutomationProperties.AutomationId="btnTimeSync"
                        AutomationProperties.Name="Time Sync Toggle"
                        AutomationProperties.HelpText="Link this pane to synchronize scrolling with other linked panes based on timestamp">
            <TextBlock x:Name="SyncIcon" FontFamily="{StaticResource CodiconFont}" FontSize="16" />
          </ToggleButton>
          <!-- Right: Metadata -->
          <TextBlock DockPanel.Dock="Right"
                     Text="{Binding HeaderMeta}"
                     ToolTip.Tip="{Binding HeaderMetaFull}"
                     Foreground="{DynamicResource DimTextBrush}"
                     VerticalAlignment="Center"
                     FontSize="11"
                     TextTrimming="CharacterEllipsis"
                     MaxWidth="200"
                     Margin="0,0,12,0" />
          <!-- Left: Title first -->
          <TextBlock DockPanel.Dock="Left"
                     Text="{Binding Title}"
                     Foreground="{DynamicResource DimTextBrush}"
                     VerticalAlignment="Center"
                     FontSize="12"
                     MaxWidth="250"
                     Margin="0,0,12,0"
                     TextTrimming="CharacterEllipsis"
                     ToolTip.Tip="{Binding Title}" />
          <!-- Left: Follow toggle -->
          <ToggleButton DockPanel.Dock="Left" Classes="neon-action pane-header-btn"
                        IsChecked="{Binding IsFollowMode}"
                        Background="Transparent" BorderThickness="0"
                        ToolTip.Tip="Follow mode&#x0a;Auto-scroll to newest lines as log grows">
            <TextBlock Text="&#xEA9A;" FontFamily="{StaticResource CodiconFont}" FontSize="16" />
          </ToggleButton>
          <!-- Left: Grid view toggle (grid icon; checked = grid, unchecked = text) -->
          <ToggleButton DockPanel.Dock="Left" Classes="neon-action pane-header-btn"
                        IsChecked="{Binding IsGridMode}"
                        Background="Transparent" BorderThickness="0"
                        ToolTip.Tip="Grid view (G)&#x0a;Table with File/Timestamp, Level, Message columns. Toggle for text view.">
            <TextBlock Text="&#xEB9F;" FontFamily="{StaticResource CodiconFont}" FontSize="16" />
          </ToggleButton>
          <!-- Left: Filter toggle -->
          <ToggleButton DockPanel.Dock="Left" Classes="neon-action pane-header-btn"
                        IsChecked="{Binding Filter.IsVisible}"
                        Background="Transparent" BorderThickness="0"
                        ToolTip.Tip="Filter / search (Ctrl+F)&#x0a;Show search and filter panel">
            <TextBlock Text="&#xEAF1;" FontFamily="{StaticResource CodiconFont}" FontSize="16" />
          </ToggleButton>
          <!-- Left: Prev file (chevron-up: previous in list) -->
          <Button DockPanel.Dock="Left" Classes="neon-action pane-header-btn"
                  Command="{Binding NavigatePrevFileCommand}"
                  IsVisible="{Binding HasMultipleFiles}"
                  Background="Transparent" BorderThickness="0"
                  ToolTip.Tip="Previous file&#x0a;Switch to the previous log file in this source">
            <TextBlock Text="&#xEAB7;" FontFamily="{StaticResource CodiconFont}" FontSize="16" />
          </Button>
          <!-- Left: Next file (chevron-down / caret) -->
          <Button DockPanel.Dock="Left" Classes="neon-action pane-header-btn"
                  Command="{Binding NavigateNextFileCommand}"
                  IsVisible="{Binding HasMultipleFiles}"
                  Background="Transparent" BorderThickness="0"
                  ToolTip.Tip="Next file&#x0a;Switch to the next log file in this source">
            <TextBlock Text="&#xEAB4;" FontFamily="{StaticResource CodiconFont}" FontSize="16" />
          </Button>
          <!-- Left: Expand all - "+ All" (only when multiple files, e.g. folder watch) -->
          <Button DockPanel.Dock="Left" Classes="neon-action pane-header-btn"
                  Command="{Binding ExpandAllFilesCommand}"
                  Content="+ All"
                  Background="Transparent" BorderThickness="0"
                  ToolTip.Tip="Expand all files&#x0a;Show all file rows expanded in grid view">
            <Button.IsVisible>
              <MultiBinding Converter="{x:Static BoolConverters.And}">
                <Binding Path="IsGridMode" />
                <Binding Path="HasMultipleFiles" />
              </MultiBinding>
            </Button.IsVisible>
          </Button>
          <!-- Left: Collapse all - "- All" (only when multiple files, e.g. folder watch) -->
          <Button DockPanel.Dock="Left" Classes="neon-action pane-header-btn"
                  Command="{Binding CollapseAllFilesCommand}"
                  Content="- All"
                  Background="Transparent" BorderThickness="0"
                  ToolTip.Tip="Collapse all files&#x0a;Show only file rows in grid view">
            <Button.IsVisible>
              <MultiBinding Converter="{x:Static BoolConverters.And}">
                <Binding Path="IsGridMode" />
                <Binding Path="HasMultipleFiles" />
              </MultiBinding>
            </Button.IsVisible>
          </Button>
        </DockPanel>
        <ProgressBar Height="2" Minimum="0" Maximum="1"
                     Value="{Binding IndexingProgress}"
                     IsVisible="{Binding IsIndexing}"
                     VerticalAlignment="Bottom"
                     Foreground="{DynamicResource AccentBrush}"
                     Background="Transparent"
                     Margin="-8,0,-8,-6" />
      </Panel>
    </Border>

    <!-- Log area + minimap (AllowDrop on children so drag-over hits a valid target and bubbles to this panel) -->
    <Grid Grid.Row="1" ColumnDefinitions="*,Auto" DragDrop.AllowDrop="True">
      <ScrollViewer x:Name="LogScroller"
                    Grid.Column="0"
                    IsVisible="{Binding !IsGridMode}"
                    DragDrop.AllowDrop="True"
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).Settings.MinimapVisible, Converter={x:Static vm:MinimapToVerticalScrollBarVisibilityConverter.Instance}}"
                    Background="{DynamicResource BackgroundBrush}">
        <ItemsRepeater ItemsSource="{Binding ItemsSource}"
                       x:Name="LogRepeater">
          <ItemsRepeater.Layout>
            <StackLayout Orientation="Vertical" Spacing="0" />
          </ItemsRepeater.Layout>
        <ItemsRepeater.ItemTemplate>
          <DataTemplate x:DataType="vm:LogLineViewModel">
              <controls:LogLineRow OwnerLogView="{Binding $parent[views:LogViewPanel].DataContext}" />
          </DataTemplate>
        </ItemsRepeater.ItemTemplate>
      </ItemsRepeater>
        <ScrollViewer.ContextMenu>
          <ContextMenu>
            <MenuItem Header="Toggle Bookmark" x:Name="MenuToggleBookmark" InputGesture="Ctrl+B" />
            <MenuItem Header="Copy Line" x:Name="MenuCopyLine" />
            <MenuItem Header="Copy Formatted JSON" x:Name="MenuCopyFormattedJson" />
            <Separator />
            <MenuItem Header="Go to Timestamp..." x:Name="MenuGoToTimestamp" InputGesture="Ctrl+G" />
            <MenuItem Header="Time Travel (Sync Others)" x:Name="MenuTimeTravel" />
            <MenuItem Header="Pin Timestamp" x:Name="MenuPinTimestamp" InputGesture="Ctrl+Shift+P" />
            <Separator />
            <MenuItem Header="Source Picker..." Command="{Binding ShowPickerCommand}" InputGesture="Ctrl+P" />
            <MenuItem Header="Highlight Rules..." x:Name="MenuHighlightRules" />
          </ContextMenu>
        </ScrollViewer.ContextMenu>
      </ScrollViewer>

      <!-- Grid mode: TreeDataGrid (toggled by G key or toolbar button) -->
      <TreeDataGrid x:Name="LogGrid"
                    Grid.Column="0"
                    IsVisible="{Binding IsGridMode}"
                    Source="{Binding GridDataSource}"
                    CanUserResizeColumns="True"
                    CanUserSortColumns="False"
                    ShowColumnHeaders="True"
                    Classes.gridlines="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).Settings.GridLinesVisible}"
                    Classes.minimap="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).Settings.MinimapVisible}"
                    Background="{DynamicResource BackgroundBrush}">
        <TreeDataGrid.ContextMenu>
          <ContextMenu>
            <MenuItem Header="Copy Line" x:Name="GridMenuCopyLine" />
            <MenuItem Header="Copy Formatted JSON" x:Name="GridMenuCopyFormattedJson" />
            <Separator />
            <MenuItem Header="Toggle Bookmark" x:Name="GridMenuToggleBookmark" InputGesture="Ctrl+B" />
            <MenuItem Header="Go to Timestamp..." x:Name="GridMenuGoToTimestamp" InputGesture="Ctrl+G" />
            <MenuItem Header="Time Travel (Sync Others)" x:Name="GridMenuTimeTravel" />
            <MenuItem Header="Pin Timestamp" x:Name="GridMenuPinTimestamp" InputGesture="Ctrl+Shift+P" />
          </ContextMenu>
        </TreeDataGrid.ContextMenu>
        <TreeDataGrid.Styles>
          <!-- Row selection highlight -->
          <Style Selector="TreeDataGridRow:selected">
            <Setter Property="Background" Value="#244FC3F7" />
          </Style>
          <Style Selector="TreeDataGridRow:pointerover">
            <Setter Property="Background" Value="#14FFFFFF" />
          </Style>
          <!-- Hide native scrollbar when minimap is visible (minimap replaces it) -->
          <Style Selector="TreeDataGrid.minimap ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Hidden" />
          </Style>
          <!-- Horizontal gridlines on rows -->
          <Style Selector="TreeDataGrid.gridlines TreeDataGridRow">
            <Setter Property="BorderBrush" Value="{DynamicResource SeparatorBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
          </Style>
          <!-- Vertical gridlines on cells -->
          <Style Selector="TreeDataGrid.gridlines :is(TreeDataGridCell)">
            <Setter Property="BorderBrush" Value="{DynamicResource SeparatorBrush}" />
            <Setter Property="BorderThickness" Value="0,0,1,0" />
          </Style>
          <!-- Suppress borders on cells nested inside expander cells to prevent doubling -->
          <Style Selector="TreeDataGrid.gridlines TreeDataGridExpanderCell :is(TreeDataGridCell)">
            <Setter Property="BorderThickness" Value="0" />
          </Style>
        </TreeDataGrid.Styles>
      </TreeDataGrid>

      <controls:LogMinimap x:Name="Minimap"
                           Grid.Column="1"
                           DragDrop.AllowDrop="True"
                           TotalLines="{Binding TotalLineCount}"
                           IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).Settings.MinimapVisible}" />

      <!-- Overlays -->
      <controls:DropZoneOverlay x:Name="DropOverlay" Grid.ColumnSpan="2" IsVisible="False" ZIndex="1000" />
      <controls:PanePickerOverlay DataContext="{Binding Picker}" Grid.ColumnSpan="2" ZIndex="1000" />
    </Grid>

    <GridSplitter x:Name="FilterSplitter"
                  Grid.Row="2"
                  Height="4"
                  Background="{DynamicResource SplitterBgBrush}"
                  ResizeDirection="Rows"
                  ResizeBehavior="PreviousAndNext" />

    <!-- Filter panel -->
    <views:FilterPanel Grid.Row="3"
                       DataContext="{Binding Filter}"
                       x:Name="FilterPanelView"
                       MinHeight="120"
                       VerticalAlignment="Stretch" />
  </Grid>
</UserControl>
