<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NovaLog.Avalonia.ViewModels"
        xmlns:views="using:NovaLog.Avalonia.Views"
        xmlns:controls="using:NovaLog.Avalonia.Controls"
        xmlns:dock="using:Dock.Avalonia.Controls"
        xmlns:docking="using:NovaLog.Avalonia.Docking"
        x:Class="NovaLog.Avalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="NovaLog (Avalonia)"
        Width="1280" Height="800"
        Background="{DynamicResource BackgroundBrush}"
        Topmost="{Binding IsTopmost}"
        TransparencyLevelHint="AcrylicBlur">

  <Grid RowDefinitions="Auto,Auto,*,24">
    <!-- Main toolbar: compact -->
    <Border Grid.Row="0"
            Background="{DynamicResource ToolBarBgBrush}"
            Padding="6,4"
            MinHeight="36">
      <Grid ColumnDefinitions="*,Auto">

        <!-- Left Side: Tools & Tabs -->
        <DockPanel Grid.Column="0" VerticalAlignment="Center">

           <!-- Right-docked: overflow, close buttons (always visible) -->
           <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4">
             <!-- Tab overflow dropdown: shows all tabs with their sources -->
             <Button Classes="neon-action toolbar-btn" x:Name="TabOverflowBtn"
                     ToolTip.Tip="All tabs"
                     Padding="4,4" MinWidth="0"
                     Click="OnTabOverflowClick">
               <TextBlock Text="&#xEAB4;" FontFamily="{StaticResource CodiconFont}" FontSize="14" />
             </Button>

             <Button Classes="neon-action toolbar-btn" Content="Close panes" Command="{Binding CloseAllPanesInActiveTabCommand}" ToolTip.Tip="Close panes&#x0a;Close all panes in this tab (sources stay in list)" Foreground="{DynamicResource DimTextBrush}" />
             <Button Classes="neon-action toolbar-btn" Content="Close tabs" Command="{Binding CloseTabsCommand}" ToolTip.Tip="Close tabs&#x0a;Close all tabs (sources stay in list)" Foreground="{DynamicResource DimTextBrush}" />
           </StackPanel>

           <!-- Left-docked: tool icons (always visible) -->
           <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="4">
             <!-- Source Manager (folder icon) -->
             <ToggleButton Classes="neon-action toolbar-btn"
                           IsChecked="{Binding IsSidebarVisible}"
                           ToolTip.Tip="Source manager (Ctrl+E)&#x0a;Open folder or file list, add/remove sources"
                           AutomationProperties.AutomationId="btnSources">
               <TextBlock Text="&#xEAF0;" FontFamily="{StaticResource CodiconFont}" FontSize="18" />
             </ToggleButton>

             <!-- Search/Filter -->
             <ToggleButton Classes="neon-action toolbar-btn"
                           IsChecked="{Binding Workspace.ActiveLogView.Filter.IsVisible}"
                           ToolTip.Tip="Filter / search (Ctrl+F)&#x0a;Show search and filter panel in active pane"
                           AutomationProperties.AutomationId="btnFilter">
               <TextBlock Text="&#xEAF1;" FontFamily="{StaticResource CodiconFont}" FontSize="18" />
             </ToggleButton>

             <!-- Follow All -->
             <ToggleButton Classes="neon-action toolbar-btn"
                           IsChecked="{Binding Workspace.IsMasterFollowOn}"
                           ToolTip.Tip="Follow all (F)&#x0a;All panes auto-scroll to newest lines"
                           AutomationProperties.AutomationId="btnFollow">
               <StackPanel Orientation="Horizontal" Spacing="4">
                 <TextBlock Text="&#xEA9A;" FontFamily="{StaticResource CodiconFont}" FontSize="18" Foreground="{DynamicResource AccentBrush}" />
                 <TextBlock Text="Follow" VerticalAlignment="Center" />
               </StackPanel>
             </ToggleButton>

             <!-- Grid View (grid icon; checked = grid, unchecked = text) -->
             <ToggleButton Classes="neon-action toolbar-btn"
                           IsChecked="{Binding Workspace.ActiveLogView.IsGridMode}"
                           ToolTip.Tip="Grid view (G)&#x0a;Table with File/Timestamp, Level, Message columns. Toggle for text view.">
               <TextBlock Text="&#xEB9F;" FontFamily="{StaticResource CodiconFont}" FontSize="18" />
             </ToggleButton>

             <Border Width="1" Background="{DynamicResource SeparatorBrush}" Margin="4,2" VerticalAlignment="Center" />

             <!-- Split Panes -->
             <Button Classes="neon-action toolbar-btn" Command="{Binding SplitHorizontalCommand}" ToolTip.Tip="Split horizontally&#x0a;Open another pane side-by-side">
               <TextBlock Text="&#xEB56;" FontFamily="{StaticResource CodiconFont}" FontSize="18" />
             </Button>
             <Button Classes="neon-action toolbar-btn" Command="{Binding SplitVerticalCommand}" ToolTip.Tip="Split vertically&#x0a;Stack another pane below">
               <TextBlock Text="&#xEB57;" FontFamily="{StaticResource CodiconFont}" FontSize="18" />
             </Button>

             <!-- Monitor Explosion -->
             <Button Classes="neon-action toolbar-btn" Command="{Binding ExplodeCommand}" ToolTip.Tip="Explode to monitors&#x0a;Distribute panes to secondary screens">
               <TextBlock Text="&#xEADF;" FontFamily="{StaticResource CodiconFont}" FontSize="18" />
             </Button>

             <Border Width="1" Background="{DynamicResource SeparatorBrush}" Margin="4,2" VerticalAlignment="Center" />
           </StackPanel>

           <!-- Center: TABS fill remaining space, clip overflow -->
           <Border ClipToBounds="True">
             <ItemsControl ItemsSource="{Binding Workspace.Tabs}" x:Name="TabBar" VerticalAlignment="Center">
               <ItemsControl.ItemsPanel>
                 <ItemsPanelTemplate>
                   <StackPanel Orientation="Horizontal" Spacing="2" />
                 </ItemsPanelTemplate>
               </ItemsControl.ItemsPanel>
               <ItemsControl.ItemTemplate>
                 <DataTemplate x:DataType="vm:WorkspaceTabItem">
                   <Button Classes="neon-tab"
                           FontWeight="{Binding IsActive, Converter={x:Static vm:BoolToFontWeightConverter.Instance}}"
                           Opacity="{Binding IsActive, Converter={x:Static vm:BoolToOpacityConverter.Instance}}"
                           AutomationProperties.Name="{Binding Name}">
                     <StackPanel Orientation="Horizontal" Spacing="4">
                       <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                       <Button Classes="neon-action tab-close-btn"
                               Tag="tab-close"
                               Content="&#x2715;"
                               FontSize="10"
                               Padding="2"
                               Margin="2,-1,0,0"
                               MinWidth="0" MinHeight="0"
                               Width="16" Height="16"
                               VerticalAlignment="Center"
                               AutomationProperties.Name="Close tab"
                               Click="OnTabCloseClick" />
                     </StackPanel>
                     <Button.ContextMenu>
                       <ContextMenu>
                         <MenuItem Header="Rename" Tag="rename" Click="OnTabContextMenuItemClick" />
                         <MenuItem Header="Close Panes" Tag="closepanes" Click="OnTabContextMenuItemClick" />
                         <MenuItem Header="Close Others" Tag="closeothers" Click="OnTabContextMenuItemClick" />
                         <MenuItem Header="Close All" Tag="closeall" Click="OnTabContextMenuItemClick" />
                         <Separator />
                         <MenuItem Header="Close" Tag="close" Click="OnTabContextMenuItemClick" />
                       </ContextMenu>
                     </Button.ContextMenu>
                   </Button>
                 </DataTemplate>
               </ItemsControl.ItemTemplate>
             </ItemsControl>
           </Border>

        </DockPanel>

        <!-- Right Side: Navigation, Simulator, Pin, Settings -->
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
           
           <TextBlock Text="{Binding Workspace.ActiveLogView.NavStatus}" Foreground="{DynamicResource DimTextBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />

           <!-- Bookmarks -->
           <Button Classes="neon-action toolbar-btn" Command="{Binding ToggleBookmarkCommand}" ToolTip.Tip="Toggle bookmark (Ctrl+B)&#x0a;Add or remove bookmark on current line">
             <TextBlock Text="&#xEAA5;" FontFamily="{StaticResource CodiconFont}" FontSize="18" Foreground="{DynamicResource BookmarkMarkerBrush}" />
           </Button>
           <Button Classes="neon-action toolbar-btn" Command="{Binding BookmarkPrevCommand}" ToolTip.Tip="Previous bookmark (Shift+F2)&#x0a;Jump to previous bookmarked line">
             <TextBlock Text="&#xEAB6;" FontFamily="{StaticResource CodiconFont}" FontSize="18" Foreground="{DynamicResource BookmarkMarkerBrush}" />
           </Button>
           <Button Classes="neon-action toolbar-btn" Command="{Binding BookmarkNextCommand}" ToolTip.Tip="Next bookmark (F2)&#x0a;Jump to next bookmarked line">
             <TextBlock Text="&#xEAB5;" FontFamily="{StaticResource CodiconFont}" FontSize="18" Foreground="{DynamicResource BookmarkMarkerBrush}" />
           </Button>

           <Border Width="1" Background="{DynamicResource SeparatorBrush}" Margin="4,2" VerticalAlignment="Center" />

           <!-- Errors -->
           <Button Classes="neon-action toolbar-btn" Command="{Binding ErrorPrevCommand}" ToolTip.Tip="Previous error (Alt+PgUp)&#x0a;Jump to previous error or fatal line">
             <TextBlock Text="&#xEAB6;" FontFamily="{StaticResource CodiconFont}" FontSize="18" Foreground="{DynamicResource TextErrorBrush}" />
           </Button>
           <Button Classes="neon-action toolbar-btn" Command="{Binding ErrorNextCommand}" ToolTip.Tip="Next error (Alt+PgDn)&#x0a;Jump to next error or fatal line">
             <TextBlock Text="&#xEAB5;" FontFamily="{StaticResource CodiconFont}" FontSize="18" Foreground="{DynamicResource TextErrorBrush}" />
           </Button>

           <Border Width="1" Background="{DynamicResource SeparatorBrush}" Margin="4,2" VerticalAlignment="Center" />

           <!-- Search Hits -->
           <Button Classes="neon-action toolbar-btn" Command="{Binding SearchPrevCommand}" ToolTip.Tip="Previous search hit (Shift+F3)&#x0a;Jump to previous filter/search match">
             <TextBlock Text="&#xEAB6;" FontFamily="{StaticResource CodiconFont}" FontSize="18" Foreground="{DynamicResource SearchHitMarkerBrush}" />
           </Button>
           <Button Classes="neon-action toolbar-btn" Command="{Binding SearchNextCommand}" ToolTip.Tip="Next search hit (F3)&#x0a;Jump to next filter/search match">
             <TextBlock Text="&#xEAB5;" FontFamily="{StaticResource CodiconFont}" FontSize="18" Foreground="{DynamicResource SearchHitMarkerBrush}" />
           </Button>

           <Border Width="1" Background="{DynamicResource SeparatorBrush}" Margin="4,2" VerticalAlignment="Center" />

           <!-- Pin -->
           <ToggleButton Classes="neon-action toolbar-btn" IsChecked="{Binding IsTopmost}" ToolTip.Tip="Stay on top (T)&#x0a;Keep window above other windows">
             <TextBlock Text="&#xEB2B;" FontFamily="{StaticResource CodiconFont}" FontSize="18" />
           </ToggleButton>

           <!-- Simulator dropdown (Gen) -->
           <DropDownButton Classes="neon-action toolbar-btn" Content="Gen"
                           Foreground="{DynamicResource DimTextBrush}"
                           ToolTip.Tip="Log generator (Gen)&#x0a;Generate sample logs for testing — choose speed in menu">
             <DropDownButton.Flyout>
               <MenuFlyout>
                 <MenuItem Header="Slow (1/s)" Command="{Binding SimSlowCommand}" />
                 <MenuItem Header="Med (5/s)" Command="{Binding SimMediumCommand}" />
                 <MenuItem Header="Fast (20/s)" Command="{Binding SimFastCommand}" />
                 <Separator />
                 <MenuItem Header="Showcase Slow" Command="{Binding SimShowcaseSlowCommand}" ToolTip.Tip="All syntax types (JSON, SQL, stack traces, numbers)" />
                 <MenuItem Header="Showcase Med" Command="{Binding SimShowcaseMediumCommand}" ToolTip.Tip="All syntax types (JSON, SQL, stack traces, numbers)" />
                 <MenuItem Header="Showcase Fast" Command="{Binding SimShowcaseFastCommand}" ToolTip.Tip="All syntax types (JSON, SQL, stack traces, numbers)" />
                 <Separator />
                 <MenuItem Header="Stop" Command="{Binding StopSimulatorCommand}" Foreground="{DynamicResource TextErrorBrush}" />
               </MenuFlyout>
             </DropDownButton.Flyout>
           </DropDownButton>

           <Border Width="1" Background="{DynamicResource SeparatorBrush}" Margin="4,2" VerticalAlignment="Center" />

           <!-- Theme -->
           <Button Classes="neon-action toolbar-btn"
                   Command="{Binding ToggleThemeCommand}"
                   ToolTip.Tip="Toggle theme&#x0a;Switch between light and dark theme"
                   AutomationProperties.AutomationId="btnTheme">
             <StackPanel Orientation="Horizontal" Spacing="4">
               <TextBlock Text="Theme:" VerticalAlignment="Center" />
               <TextBlock Text="{Binding ThemeLabel}" FontWeight="Bold" VerticalAlignment="Center" />
             </StackPanel>
           </Button>

           <!-- Theme Marketplace (native: search, fetch, apply VS Code themes) -->
           <Button Classes="neon-action toolbar-btn" Click="OnThemeMarketplaceClick"
                   ToolTip.Tip="Theme Marketplace&#x0a;Import VS Code themes (native, no browser)"
                   AutomationProperties.AutomationId="btnThemeMarketplace">
             <TextBlock Text="&#xEADF;" FontFamily="{StaticResource CodiconFont}" FontSize="18" />
           </Button>

           <!-- Settings -->
           <ToggleButton Classes="neon-action toolbar-btn" IsChecked="{Binding Settings.IsVisible}" ToolTip.Tip="Settings (Ctrl+,)&#x0a;Open settings flyout">
             <TextBlock Text="&#xEAF8;" FontFamily="{StaticResource CodiconFont}" FontSize="18" />
           </ToggleButton>

        </StackPanel>

      </Grid>
    </Border>

    <!-- Time Sync Bar -->
    <controls:TimeSyncBar Grid.Row="1" DataContext="{Binding Workspace.TimeSync}" />

    <!-- Content area -->
    <Grid Grid.Row="2" ColumnDefinitions="260,Auto,*,Auto">
      <views:SourceManagerPanel Grid.Column="0"
                                 MinWidth="200"
                                 IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsSidebarVisible}"
                                 DataContext="{Binding SourceManager}"
                                 x:Name="SidebarPanel"
                                 AutomationProperties.AutomationId="sourceManagerPanel" />

      <GridSplitter Grid.Column="1" Width="3"
                    Background="{DynamicResource SplitterBgBrush}"
                    IsVisible="{Binding IsSidebarVisible}" />

      <dock:DockControl Grid.Column="2"
                        Layout="{Binding Workspace.Layout}"
                        Factory="{Binding Workspace.DockFactory}"
                        InitializeLayout="True"
                        EnableManagedWindowLayer="False"
                        AutomationProperties.AutomationId="logViewPanel" />

      <!-- Settings flyout (right-docked) -->
      <views:SettingsFlyout Grid.Column="3"
                            DataContext="{Binding Settings}" />
    </Grid>

    <!-- Status bar -->
    <Border Grid.Row="3"
            Background="{DynamicResource StatusBarBgBrush}"
            Padding="8,2">
      <Grid ColumnDefinitions="*,Auto,Auto,Auto">
        <TextBlock Text="{Binding StatusFile}"
                   Foreground="{DynamicResource DimTextBrush}"
                   FontSize="11"
                   TextTrimming="CharacterEllipsis"
                   VerticalAlignment="Center"
                   AutomationProperties.Name="{Binding StatusFile}"
                   AutomationProperties.AutomationId="lblFile" />
        <TextBlock Grid.Column="1"
                   Text="{Binding StatusStreaming}"
                   Foreground="{DynamicResource AccentBrush}"
                   FontSize="11" Margin="12,0"
                   VerticalAlignment="Center"
                   AutomationProperties.Name="{Binding StatusStreaming}"
                   AutomationProperties.AutomationId="lblStreaming" />
        <TextBlock Grid.Column="2"
                   Text="{Binding StatusLines}"
                   Foreground="{DynamicResource AccentBrush}"
                   FontSize="11" Margin="12,0"
                   VerticalAlignment="Center"
                   AutomationProperties.Name="{Binding StatusLines}"
                   AutomationProperties.AutomationId="lblLines" />
        <TextBlock Grid.Column="3"
                   Text="{Binding StatusFollow}"
                   Foreground="{DynamicResource DimTextBrush}"
                   FontSize="11"
                   VerticalAlignment="Center"
                   AutomationProperties.Name="{Binding StatusFollow}"
                   AutomationProperties.AutomationId="lblFollow" />
      </Grid>
    </Border>
  </Grid>
</Window>
