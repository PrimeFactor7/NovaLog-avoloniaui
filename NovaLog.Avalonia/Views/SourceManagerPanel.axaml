<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NovaLog.Avalonia.ViewModels"
             x:Class="NovaLog.Avalonia.Views.SourceManagerPanel"
             x:DataType="vm:SourceManagerViewModel">

  <ExperimentalAcrylicBorder Material="{StaticResource NeonAcrylicMaterial}">
    <Border Classes="neon-sidebar">
      <DockPanel>
        
        <!-- Header -->
        <Border Classes="neon-header" DockPanel.Dock="Top">
          <DockPanel>
            <Button DockPanel.Dock="Right" Classes="neon-action" Content="&#x2715;" 
                    Command="{Binding CloseSidebarCommand}" 
                    Width="24" Height="24" Padding="0" Margin="0,0,-4,0" />
            <TextBlock Classes="neon-title" Text="&#x2630;  Sources" VerticalAlignment="Center" />
          </DockPanel>
        </Border>

        <!-- Action bar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                    Spacing="4" Margin="6,6">
          <Button Classes="neon-action" Click="OnAddFolderClick"
                  ToolTip.Tip="Add Folder">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="&#xED25;" FontFamily="Segoe MDL2 Assets, Avalonia.Fonts.Inter" FontSize="12" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" />
              <TextBlock Text="Folder" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
          <Button Classes="neon-action" Click="OnAddFileClick"
                  ToolTip.Tip="Add File">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets, Avalonia.Fonts.Inter" FontSize="12" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" />
              <TextBlock Text="File" VerticalAlignment="Center" />
            </StackPanel>
          </Button>

          <Border Width="1" Background="{DynamicResource SeparatorBrush}" Margin="2" />

          <Button Classes="neon-action" Click="OnRecentHistoryClick" ToolTip.Tip="Open Recent History">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets, Avalonia.Fonts.Inter" FontSize="12" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" />
              <TextBlock Text="Recent" VerticalAlignment="Center" />
            </StackPanel>
          </Button>

          <Border Width="1" Background="{DynamicResource SeparatorBrush}" Margin="2" />

          <Button Classes="neon-action" Command="{Binding ToggleSelectAllCommand}" ToolTip.Tip="Select All">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="&#xE762;" FontFamily="Segoe MDL2 Assets, Avalonia.Fonts.Inter" FontSize="12" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" />
              <TextBlock Text="All" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
          <Button Classes="neon-action" Command="{Binding ClearSelectedCommand}" IsEnabled="{Binding CanClear}" ToolTip.Tip="Clear Selected">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets, Avalonia.Fonts.Inter" FontSize="12" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" />
              <TextBlock Text="Clear" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
        </StackPanel>

        <Border Classes="neon-separator" DockPanel.Dock="Top" />

        <!-- Footer -->
        <Border DockPanel.Dock="Bottom" Classes="neon-header">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Classes="neon-status"
                       Text="{Binding MergeStatusText}"
                       VerticalAlignment="Center" />
            <Button Grid.Column="1" Classes="neon-action"
                    Content="Merge"
                    Command="{Binding MergeSelectedCommand}"
                    IsEnabled="{Binding CanMerge}" />
          </Grid>
        </Border>

        <!-- Source list -->
        <ListBox x:Name="SourceListBox"
                 ItemsSource="{Binding DisplaySources}"
                 SelectedItem="{Binding SelectedSource}"
                 Background="Transparent"
                 DoubleTapped="OnSourceDoubleTapped">
          <ListBox.ContextMenu>
            <ContextMenu>
              <MenuItem Header="Load" Command="{Binding LoadSelectedCommand}" />
              <MenuItem Header="Open in New Tab" Command="{Binding OpenInNewTabCommand}" />
              <Separator />
              <MenuItem Header="Set Alias..." Command="{Binding SetAliasCommand}" />
              <MenuItem Header="Remove" Command="{Binding RemoveSelectedCommand}" />
              <Separator />
              <MenuItem Header="Show in Explorer" Command="{Binding ShowInExplorerCommand}" />
            </ContextMenu>
          </ListBox.ContextMenu>
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:SourceItemViewModel">
              <Grid ColumnDefinitions="Auto,Auto,*,Auto" Margin="{Binding IsChild, Converter={x:Static vm:IndentConverter.Instance}}">
                
                <!-- Checkbox for top-level, non-merge items -->
                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelectedForMerge}" 
                          IsVisible="{Binding CanSelectForMerge}" 
                          Margin="0,0,6,0" VerticalAlignment="Center" />
                          
                <!-- Merge controls -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="4"
                            IsVisible="{Binding IsMergeSource}"
                            Margin="0,0,6,0"
                            VerticalAlignment="Center">
                  <ToggleButton IsChecked="{Binding IsExpanded}"
                                Classes="neon-action" Width="20" Height="20" Padding="0" Background="Transparent">
                    <TextBlock Text="{Binding IsExpanded, Converter={x:Static vm:ChevronConverter.Instance}}"
                               FontFamily="Segoe MDL2 Assets, Avalonia.Fonts.Inter" FontSize="10"
                               Foreground="{DynamicResource DimTextBrush}" />
                  </ToggleButton>
                  <Button Classes="neon-action"
                          Width="20" Height="20" Padding="0"
                          Background="Transparent"
                          Command="{Binding $parent[UserControl].DataContext.RemoveSourceItemCommand}"
                          CommandParameter="{Binding}"
                          ToolTip.Tip="Remove merged view">
                    <TextBlock Text="&#x2715;" FontSize="10" />
                  </Button>
                </StackPanel>

                <!-- Color Pip / Bar -->
                <Ellipse Grid.Column="1" Classes="neon-pip"
                         IsVisible="{Binding ShowSourcePip}"
                         Margin="0,0,6,0"
                         VerticalAlignment="Center"
                         Width="10" Height="10"
                         Fill="{Binding SourceColorHex, Converter={x:Static vm:HexToColorConverter.Instance}}" />
                <Border Grid.Column="1" Width="4" Height="14" CornerRadius="2"
                        IsVisible="{Binding ShowChildColorBar}" Margin="6,0,6,0" VerticalAlignment="Center"
                        Background="{Binding SourceColorHex, Converter={x:Static vm:HexToColorConverter.Instance}}" />

                <!-- Name -->
                <TextBlock Grid.Column="2" Text="{Binding DisplayName}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" 
                           Opacity="{Binding IsMissing, Converter={x:Static vm:MissingOpacityConverter.Instance}}"
                           FontStyle="{Binding IsMissing, Converter={x:Static vm:MissingFontStyleConverter.Instance}}" />
                           
                <!-- Kind Label -->
                <TextBlock Grid.Column="3" Text="{Binding KindLabel}"
                           Foreground="{DynamicResource DimTextBrush}" FontSize="9"
                           VerticalAlignment="Center" Margin="4,0" />
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="Padding" Value="4" />
              <Setter Property="Background" Value="Transparent" />
              <Setter Property="Foreground" Value="{DynamicResource DimTextBrush}" />
              <Setter Property="CornerRadius" Value="3" />
              <Setter Property="Margin" Value="2,1" />
            </Style>
            <Style Selector="ListBoxItem:pointerover">
              <Setter Property="Background" Value="{DynamicResource TabHoverBgBrush}" />
            </Style>
            <Style Selector="ListBoxItem:selected">
              <Setter Property="Background" Value="{DynamicResource TabActiveBgBrush}" />
              <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
            </Style>
          </ListBox.Styles>
        </ListBox>
      </DockPanel>
    </Border>
  </ExperimentalAcrylicBorder>
</UserControl>
