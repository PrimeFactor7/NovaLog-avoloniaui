<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:psp="using:Dock.Controls.ProportionalStackPanel"
        xmlns:dock="using:Dock.Avalonia.Controls">

  <!-- Spillover menus: render above dock layer and do not clip (plan: ZIndex 100, ClipToBounds False). Note: MenuFlyout has no ZIndex/ClipToBounds in Avalonia; ContextMenu gets these. -->
  <Style Selector="ContextMenu">
    <Setter Property="ZIndex" Value="100" />
    <Setter Property="ClipToBounds" Value="False" />
  </Style>

  <!-- 1px Neon Cyan splitters (visible by default); pointerover keeps same for discoverability -->
  <Style Selector="psp|ProportionalStackPanelSplitter">
    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Thickness" Value="1" />
    <Setter Property="ZIndex" Value="50" />
  </Style>
  <Style Selector="psp|ProportionalStackPanelSplitter:pointerover">
    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
  </Style>

  <!-- DocumentTabStrip: minimal, transparent, shows when multiple docs share a DocumentDock (tab-merge) -->
  <Style Selector="dock|DocumentTabStrip">
    <Setter Property="Height" Value="24" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Opacity" Value="0.7" />
  </Style>
  <Style Selector="dock|DocumentTabStripItem">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="Foreground" Value="{DynamicResource DimTextBrush}" />
    <Setter Property="Padding" Value="8,2" />
  </Style>
  <!-- :active is Dock's pseudo-class for the active document (not :selected) -->
  <Style Selector="dock|DocumentTabStripItem:active">
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
  </Style>

  <!-- Minimum pane dimensions to enforce Tab Fairness (250px) -->
  <Style Selector="dock|DocumentDockControl">
    <Setter Property="MinWidth" Value="250" />
    <Setter Property="MinHeight" Value="250" />
  </Style>

  <!-- Floating HostWindow: Full resize handles, no drawn chrome, 1px Neon Cyan border -->
  <Style Selector="dock|HostWindow">
    <Setter Property="Background" Value="{DynamicResource BackgroundBrush}" />
    <Setter Property="SystemDecorations" Value="Full" />
    <Setter Property="ExtendClientAreaToDecorationsHint" Value="True" />
    <Setter Property="ExtendClientAreaChromeHints" Value="NoChrome" />
    <Setter Property="ExtendClientAreaTitleBarHeightHint" Value="-1" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>
</Styles>
